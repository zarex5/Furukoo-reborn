# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/furukoo

# Required in production — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production

# Server port (default: 3001)
PORT=3001

# Restrict CORS to your domain in production, e.g. https://furukoo.com
# Leave unset or * for local dev (default: *)
ALLOWED_ORIGIN=

# Username to promote to admin on startup (idempotent, optional)
# Set once after first deploy, then remove or leave blank
ADMIN_USERNAME=
